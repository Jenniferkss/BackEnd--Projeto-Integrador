generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Livro {
    id        Int      @id @default(autoincrement())
    titulo      String
    imagens     String [] @default([])
    autor       String
    dataLancamento      Int
    descricao       String
    contextoHistorico     String

    reviews     Reviews[]
    personagem Personagem[]

    @@map("livro")
}

model Personagem {
    id      Int  @id @default(autoincrement())
    nome    String
    idade   Int
    descricao       String
    imagens     String [] @default([])
    livroId     Int

    livro Livro?  @relation(fields: [livroId],references: [id])
    @@map("personagem")
}

model Reviews {
     id        Int      @id @default(autoincrement())
     comentario     String

     livroId     Int

     livro Livro?  @relation(fields: [livroId],references: [id]) 
     @@map("review")     
}