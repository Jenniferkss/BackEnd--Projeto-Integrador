generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Livro {
    id                  Int              @id @default(autoincrement())
    tituloPT            String
    tituloEN            String
    capaURl             String?
    autor               String
    anoPublicacao       Int?
    generoPT            String
    generoEN            String
    descricaoPT         String           @db.Text
    descricaoEN         String           @db.Text
    personagens         String[]
    contextoHistoricoPT String           @db.Text
    contextoHistoricoEN String           @db.Text
    analisePT           String
    analiseEN           String
    reviews             Review[]
    videoAulas          Videoaula[]
    curiosidades        Curiosidade[]
    dicasVestibular     DicaVestibular[]
    simulados           Simulado[]

    @@map("livro")
}

model Review {
    id           Int      @id @default(autoincrement())
    livroId      Int
    livro        Livro    @relation(fields: [livroId], references: [id])
    autor        String
    comentarioPt String   @db.Text
    comentarioEn String   @db.Text
    avaliacao    Int // Ex: 1 a 5 estrelas
    data         DateTime @default(now())

    @@map("reviews")
}

model Videoaula {
    id          Int     @id @default(autoincrement())
    livroId     Int
    livro       Livro   @relation(fields: [livroId], references: [id])
    tituloPt    String
    tituloEn    String
    urlMidia    String
    descricaoPt String? @db.Text
    descricaoEn String? @db.Text

    @@map("videoaulas")
}

model Curiosidade {
    id         Int    @id @default(autoincrement())
    livroId    Int
    livro      Livro  @relation(fields: [livroId], references: [id])
    tituloPt   String
    tituloEn   String
    conteudoPt String @db.Text
    conteudoEn String @db.Text

    @@map("curiosidades")
}

model DicaVestibular {
    id         Int    @id @default(autoincrement())
    livroId    Int
    livro      Livro  @relation(fields: [livroId], references: [id])
    tituloPt   String
    tituloEn   String
    conteudoPt String @db.Text
    conteudoEn String @db.Text

    @@map("dicas_vestibular")
}

model Simulado {
    id       Int    @id @default(autoincrement())
    livroId  Int
    livro    Livro  @relation(fields: [livroId], references: [id])
    tituloPt String
    tituloEn String

    questoes Questao[]

    @@map("simulados")
}

model Questao {
    id                Int           @id @default(autoincrement())
    simuladoId        Int
    simulado          Simulado      @relation(fields: [simuladoId], references: [id])
    perguntaPt        String        @db.Text
    perguntaEn        String        @db.Text
    alternativas      Alternativa[]
    respostaCorretaPt String        @map("resposta_correta_pt")
    respostaCorretaEn String        @map("resposta_correta_en")
    explicacaoPt      String?       @db.Text
    explicacaoEn      String?       @db.Text

    @@map("questoes")
}

model Alternativa {
    id        Int     @id @default(autoincrement())
    questaoId Int
    questao   Questao @relation(fields: [questaoId], references: [id])
    textoPt   String?
    textoEn   String?

    @@map("alternativas")
}

model Equipe {
    id         Int    @id @default(autoincrement())
    nome       String
    curso      String
    objetivoPt String @db.Text
    objetivoEn String @db.Text

    @@map("equipes")
}
