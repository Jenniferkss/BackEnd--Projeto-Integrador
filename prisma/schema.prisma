generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Livro {
    id        Int      @id @default(autoincrement())
    titulo      String
    preco     Decimal? @db.Decimal(10, 2)
    imagens     String
    autor       String
    dataLancamento      String
    descricao       String
    reviews     String
    contextoHistorico     String
    @@map("exemplo")
}
